#!/usr/bin/env bash
# wow-locate — resolve a claude-wow plugin-relative path to an absolute path.
#
# Usage: wow-locate <plugin-relative-path>
#   e.g. wow-locate commands/_agent-protocol.md
#
# Resolution order:
#   1. Project-local override — <project-dir>/.claude/<path>
#   2. Plugin install        — <plugin-root>/<path>
# where <plugin-root> is derived from this script's own location, so it is
# correct regardless of marketplace name or version directory.
#
# Prints the absolute path on stdout (exit 0). On a miss, prints a one-line
# diagnostic to stderr and exits non-zero.
set -u

rel="${1:-}"
if [ -z "$rel" ]; then
  echo "wow-locate: usage: wow-locate <plugin-relative-path>" >&2
  exit 2
fi

# Bug 0002, Layer C — recursion guard. A test stub or supervisor script
# that creates a PATH-shadowing wrapper named `wow-locate` delegating to
# `wow-locate "$@"` would land in a tight infinite loop (PATH lookup
# keeps resolving to the stub; each recursion is a fresh bash process;
# CC's Monitor re-arms; cascading host-wide fork bomb). Detection:
# compare this script's inode to the next `wow-locate` on PATH beyond
# our own directory. Same inode → PATH-shadow class → refuse, exit 3.
_wls=$0
case "$_wls" in
  /*) ;;
  *)  _wls=$(command -v "$0" 2>/dev/null) ;;
esac
if [ -n "$_wls" ] && [ -f "$_wls" ]; then
  _wls_dir=$(cd "$(dirname "$_wls")" && pwd)
  _self_inode=$(/bin/ls -i "$_wls" 2>/dev/null | awk '{print $1}')
  IFS=: read -r -a _path_dirs <<< "$PATH"
  for _candidate_dir in "${_path_dirs[@]}"; do
    [ -z "$_candidate_dir" ] && continue
    [ "$_candidate_dir" = "$_wls_dir" ] && continue
    _candidate="$_candidate_dir/wow-locate"
    if [ -f "$_candidate" ]; then
      _candidate_inode=$(/bin/ls -i "$_candidate" 2>/dev/null | awk '{print $1}')
      if [ -n "$_self_inode" ] && [ "$_self_inode" = "$_candidate_inode" ]; then
        printf 'wow-locate: PATH-shadow recursion detected (self at %s == next-on-PATH at %s). Refusing to continue (fork-bomb class).\n' \
          "$_wls" "$_candidate" >&2
        exit 3
      fi
      break
    fi
  done
fi

# Plugin root = parent of this script's bin/ directory. A PATH-invoked script
# sees its own absolute path in $0 (the shell execve's the resolved path).
script_dir=$(cd "$(dirname "$0")" && pwd)
plugin_root=$(cd "$script_dir/.." && pwd)

# Project dir for the .claude/ override convention. CLAUDE_PROJECT_DIR is unset
# in an agent's Bash shell, so fall back to the git toplevel.
project_dir="${CLAUDE_PROJECT_DIR:-}"
if [ -z "$project_dir" ]; then
  project_dir=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
fi

override="$project_dir/.claude/$rel"
if [ -e "$override" ]; then
  printf '%s\n' "$override"
  exit 0
fi

installed="$plugin_root/$rel"
if [ -e "$installed" ]; then
  printf '%s\n' "$installed"
  exit 0
fi

echo "wow-locate: not found: $rel (checked $override and $installed)" >&2
exit 1
