#!/usr/bin/env bash
# wow-attention — play the M attention sound. Cross-platform; a silent no-op
# (exit 0) when no audio player is available, so a non-audio environment
# (CI, headless) never errors. The WAV is resolved relative to this script's
# own location (same plugin-root derivation as wow-locate).
set -u

script_dir=$(cd "$(dirname "$0")" && pwd)
wav="$script_dir/../assets/attention.wav"
[ -f "$wav" ] || exit 0

case "$(uname -s 2>/dev/null)" in
  Darwin)
    command -v afplay >/dev/null 2>&1 && exec afplay "$wav"
    ;;
  Linux)
    command -v paplay >/dev/null 2>&1 && exec paplay "$wav"
    command -v aplay  >/dev/null 2>&1 && exec aplay -q "$wav"
    if command -v powershell.exe >/dev/null 2>&1; then
      win=$(wslpath -w "$wav" 2>/dev/null || printf '%s' "$wav")
      exec powershell.exe -NoProfile -Command "(New-Object Media.SoundPlayer '$win').PlaySync()"
    fi
    ;;
  MINGW*|MSYS*|CYGWIN*)
    if command -v powershell >/dev/null 2>&1; then
      exec powershell -NoProfile -Command "(New-Object Media.SoundPlayer '$wav').PlaySync()"
    fi
    ;;
esac
exit 0
